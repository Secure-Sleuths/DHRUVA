{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  // vitest.config.ts is excluded: it imports @vitejs/plugin-react, whose d.ts
  // uses syntax newer than the pinned TypeScript can PARSE (skipLibCheck does
  // not help — parsing still fails). Vitest loads the config itself; the test
  // files remain fully typechecked via the include above.
  "exclude": ["node_modules", "vitest.config.ts"]
}
