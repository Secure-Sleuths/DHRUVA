# =============================================================================
# SecureSleuths DHRUVA — Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# ── License ─────────────────────────────────────────────────────────────────
# Path to license file (provided by SecureSleuths)
LICENSE_FILE=license.key
# Build profile: auto, community, or full. "auto" runs Community when no
# license file exists and switches to full automatically when a valid license
# is later added.
DHRUVA_BUILD_PROFILE=community

# ── Wazuh Connection ───────────────────────────────────────────────────────
# Full URL to your Wazuh Manager API (including https://)
WAZUH_API_URL=https://YOUR_WAZUH_IP
# Full URL to your Wazuh Indexer / OpenSearch (including https:// and port)
OPENSEARCH_URL=https://YOUR_WAZUH_IP:9200

WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=
# SSH access to Wazuh manager (for wazuh-logtest rule validation)
WAZUH_SSH_USER=
WAZUH_SSH_PASSWORD=

# ── OpenSearch / Wazuh Indexer ──────────────────────────────────────────────
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=

# ── LLM Provider ───────────────────────────────────────────────────────────
# The deploy.sh wizard sets these based on your chosen provider.
# Only fill in the section for your chosen provider.

# Anthropic Claude (default)
# Option A: API key (recommended for Docker / production)
ANTHROPIC_API_KEY=
# Option B: Leave blank — platform auto-detects `claude` CLI if installed
#           (requires Claude Code installed + Max subscription logged in)

# OpenAI / Azure OpenAI / OpenAI-compatible proxy (LiteLLM, vLLM, etc.)
OPENAI_API_KEY=
# Custom base URL for OpenAI-compatible providers. Leave blank for api.openai.com.
# Examples: http://litellm.example.com:4000, https://your-azure-resource.openai.azure.com
OPENAI_BASE_URL=

# Groq (cloud-hosted Llama)
GROQ_API_KEY=

# Ollama — no API key needed, runs locally (set base_url in config.yaml)

# ── Threat Intelligence ─────────────────────────────────────────────────────
# Free API keys — sign up at each provider's website
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
THREATFOX_API_KEY=

# ── Platform Authentication ─────────────────────────────────────────────────
# JWT secret — leave blank to auto-generate a strong secret on first run
JWT_SECRET=
# Initial admin account (created on first startup if no users exist)
SOC_ADMIN_USER=admin
SOC_ADMIN_PASSWORD=
SOC_ADMIN_ROLE=admin
# Deployment mode: "single_tenant" or "multi_tenant"
DEPLOYMENT_MODE=single_tenant

# ── Multi-Tenant (MSSP) ────────────────────────────────────────────────────
# Only needed if DEPLOYMENT_MODE=multi_tenant
# Fernet encryption key for client configs — auto-generated by deploy.sh
TENANT_ENCRYPTION_KEY=
# Key rotation (see docs/KEY-ROTATION.md). During a rotation set the previous
# master here and bump TENANT_KEY_GENERATION; otherwise leave both unset.
# TENANT_ENCRYPTION_KEY_OLD=
# Current master generation (default 1). Bump by 1 on EACH rotation (1->2->3…).
# TENANT_KEY_GENERATION=1
# First tenant details (set by deploy.sh)
FIRST_TENANT_NAME=
FIRST_TENANT_SLUG=

# ── Anonymization ───────────────────────────────────────────────────────
# Salt for LLM prompt anonymization — auto-generated by deploy.sh
# Must persist across restarts for consistent token mapping
ANONYMIZATION_SALT=

# ── Notifications (optional) ────────────────────────────────────────────────
# Slack — get webhook URL from https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Email (SMTP)
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Ticketing Integration (optional) ───────────────────────────────────────
# Jira
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_WEBHOOK_SECRET=

# ServiceNow
SERVICENOW_USER=
SERVICENOW_PASSWORD=
SERVICENOW_WEBHOOK_SECRET=

# PagerDuty
PAGERDUTY_ROUTING_KEY=
PAGERDUTY_API_TOKEN=
PAGERDUTY_WEBHOOK_SECRET=

# ── Database (REQUIRED in v4.9.0+) ──────────────────────────────────────────
# Postgres is now the only supported backend (SQLite retired in v4.9.0).
# For the bundled docker-compose Postgres service, set POSTGRES_PASSWORD
# below and leave DATABASE_URL empty — compose will build the DSN.
# For an external Postgres, set DATABASE_URL directly.
DATABASE_URL=
POSTGRES_USER=dhruva
POSTGRES_PASSWORD=
POSTGRES_DB=dhruva

# ── Docker Settings ─────────────────────────────────────────────────────────
# Dashboard port (default: 8443)
SOC_PORT=8443
# Timezone
TZ=UTC
