venv/
__pycache__/
*.pyc
*.pyo
.env
*.db
*.sqlite
.DS_Store
node_modules/
.pytest_cache/
.pytest_run.log
.coverage
.coverage.*
htmlcov/
coverage.xml

# Claude Code runtime artifacts (locks, transcripts) — not source.
# Exceptions: .claude/agents/ (role definitions) and .claude/settings.json (shared
# project permissions/allow-list) ARE source. settings.local.json stays ignored.
.claude/*
!.claude/agents/
!.claude/settings.json

# Build artifacts
# Ignore the whole dist/ tree — the previous `dist/*.tar.gz` glob missed the
# checksum/manifest sidecars the client-package build drops alongside tarballs.
dist/
build/
*.spec.bak

# Generated frontend build (Option 1: built at release time, never committed).
# web/out is the Next.js static export; src/api/static/app is where the deploy
# step (scripts/build-web.sh) stages it for the FastAPI backend to serve.
web/out/
src/api/static/app/

# Licensing (private keys, client license files, and manager artifacts)
keys/
license.key
tools/license-manager/ledger.json
tools/license-manager/licenses/
tools/license-manager/*.key

# Sales — rendered derivatives (re-render from .md sources)
sales/*.pptx
sales/*.pdf
